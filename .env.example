# Puerto del servidor
PORT=3000
 
# Cadena de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>
 
# Clave secreta para JWT (usar una cadena larga y aleatoria)
JWT_SECRET=reemplazar_con_clave_secreta
 
# Entorno de ejecución
NODE_ENV=production
 
# URL del frontend (para configurar CORS)
FRONTEND_URL=https://tu-distribucion.cloudfront.net
# Configuración de AWS S3 para almacenamiento de archivos
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_REGION=tu_region
AWS_S3_BUCKET=tu_nombre_de_bucket